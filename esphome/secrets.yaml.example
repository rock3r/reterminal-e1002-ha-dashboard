# Copy this file to `secrets.yaml` (same directory) and fill in your values.
# `secrets.yaml` is gitignored — never commit it.

wifi_ssid: "Your WiFi SSID"
wifi_password: "Your WiFi password"

# ESPHome API encryption key — a base64-encoded 32-byte key.
# Generate one with either:
#   - the ESPHome dashboard: "Edit" a device -> it offers to generate a key, or
#   - openssl:   openssl rand -base64 32
api_encryption_key: "PUT_A_GENERATED_BASE64_32_BYTE_KEY_HERE="
